{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "COMIC-Bridge-Integrated",
  "version": "3.6.4",
  "identifier": "com.comic-bridge-integrated.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "COMIC-Bridge 統合版",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "scripts/*": "scripts/",
      "icons/icon.ico": "comic-bridge.ico",
      "resources/pdfium/pdfium.dll": "resources/pdfium/pdfium.dll"
    },
    "windows": {
      "nsis": {
        "languages": ["Japanese"],
        "displayLanguageSelector": false,
        "installerHooks": "windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yamamoto-ryusei-ux/COMIC-Bridge-integrated/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA5OThEQ0U5MDA4OUVFRTMKUldUajdva0E2ZHlZQ2FydWVSSjlhSVcrTlY3RXdmbWk2MlFjM2s2b0NxT0w3L0JwclhUL0NBWHIK"
    }
  }
}
